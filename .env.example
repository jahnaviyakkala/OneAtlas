# ProtoFlow Environment Variables - EXAMPLE
# Copy this file to .env and fill in your real values.

# ── OpenRouter (kept as fallback, not used for main pipeline) ─────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Groq (primary LLM provider for all 10 agents) ────────────────────────────
# Free key at https://console.groq.com
# Free tier: 1K RPM, 300K TPM - sufficient for full pipeline runs
# Model used: llama-3.3-70b-versatile
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_2=    # Optional second Gemini key for rotation on rate limits

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug

# ── Pipeline tuning ───────────────────────────────────────────────────────────
MAX_REPAIR_LOOPS=3
HITL_TIMEOUT_SECONDS=300
SESSION_STORE=memory

# ── LLM temperatures ──────────────────────────────────────────────────────────
DEFAULT_TEMPERATURE_SCHEMA=0.2
DEFAULT_TEMPERATURE_INTENT=0.4
DEFAULT_TEMPERATURE_VALIDATOR=0.1
DEFAULT_TEMPERATURE_LOGGER=0.3

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000